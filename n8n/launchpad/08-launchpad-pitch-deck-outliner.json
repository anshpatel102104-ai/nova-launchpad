              "name": "type",
              "value": "pitch_deck"
            },
            {
              "name": "created_at",
              "value": "=now()"
            }
          ]
        },
        "body": "{\n  \"user_id\": \"{{ $json.body.user_id }}\",\n  \"tool\": \"pitch_deck_outliner\",\n  \"type\": \"pitch_deck\",\n  \"metadata\": {\n    \"company_name\": \"{{ $json.body.company_name }}\",\n    \"deck_type\": \"{{ $json.body.deck_type }}\",\n    \"ask_amount\": \"{{ $json.body.ask_amount }}\"\n  },\n  \"payload\": {\n    \"company_name\": \"{{ $json.body.company_name }}\",\n    \"problem\": \"{{ $json.body.problem }}\",\n    \"solution\": \"{{ $json.body.solution }}\",\n    \"traction\": \"{{ $json.body.traction }}\",\n    \"ask_amount\": \"{{ $json.body.ask_amount }}\",\n    \"deck_type\": \"{{ $json.body.deck_type }}\",\n    \"slides\": {{ JSON.stringify($json.slides) }}\n  },\n  \"created_at\": \"now()\"\n}",
        "options": {
          "headers": {
            "headers": [
              {
                "name": "apikey",
                "value": "={{ $env.SUPABASE_KEY }}"
              },
              {
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        }
      },
