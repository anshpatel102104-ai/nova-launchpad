    {
      "parameters": {
        "url": "={{ $env.ANTHROPIC_API_URL }}/v1/messages",
        "method": "POST",
        "authentication": "none",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "claude-opus-4-20250805"
            },
            {
              "name": "max_tokens",
              "value": "4000"
            }
          ]
        },
        "body": "{\n  \"model\": \"claude-opus-4-20250805\",\n  \"max_tokens\": 4000,\n  \"system\": \"You are an expert offer architect specializing in high-converting B2B SaaS offers. You understand value equations, price anchoring, urgency/scarcity mechanics, and persuasion psychology. Generate a complete offer stack based on Alex Hormozi's offer framework: dream outcome, likelihood of achievement, time to achievement, effort/sacrifice required, bonus stack (5 bonuses with $ values), guarantee, scarcity element, urgency element, and complete offer copy. OUTPUT ONLY VALID JSON with no markdown formatting or extra text. Format: { \\\"dream_outcome\\\": \\\"\\\", \\\"value_equation\\\": { \\\"likelihood\\\": \\\"\\\", \\\"time_delay\\\": \\\"\\\", \\\"effort_sacrifice\\\": \\\"\\\" }, \\\"bonuses\\\": [{ \\\"name\\\": \\\"\\\", \\\"value\\\": number }, ...], \\\"guarantee\\\": \\\"\\\", \\\"scarcity\\\": \\\"\\\", \\\"urgency\\\": \\\"\\\", \\\"offer_copy\\\": \\\"\\\", \\\"total_value\\\": number, \\\"anchor_price\\\": number }\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Build a high-converting offer for: Core Product: {{ $json.body.core_product }}, Target Market: {{ $json.body.target_market }}, Price Target: ${{ $json.body.price_target }}, Brand Voice: {{ $json[0].brand_voice || 'professional and direct' }}, Tone: {{ $json[0].tone || 'consultative' }}. Create dream outcome, value equation (likelihood, time, effort), 5 bonuses with $ values, money-back guarantee, scarcity (specific limit), urgency (deadline), complete offer copy, calculate total bonus value and anchor price (3x offer price). Return ONLY JSON.\"\n    }\n  ]\n}"
      },
      "id": "call_claude_api",
      "name": "Call Claude Offer Builder",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1450, 300],
      "onError": "continueErrorOutput",
      "credentials": [
        {
          "name": "anthropicApi",
          "type": "anthropicApi"
        }
      ]
    },
    {
      "parameters": {
        "jsCode": "// Extract Claude response from nested structure\nconst responseContent = $json.content[0].text;\n\n// Parse JSON from Claude\nlet offer;\ntry {\n  offer = JSON.parse(responseContent);\n} catch(e) {\n  // If Claude wrapped in markdown backticks, extract it\n  const jsonMatch = responseContent.match(/```json\\n?(.*?)\\n?```/s);\n  if (jsonMatch) {\n    offer = JSON.parse(jsonMatch[1]);\n  } else if (responseContent.match(/^\\{/)) {\n    // Try raw object\n    offer = JSON.parse(responseContent);\n  } else {\n    throw new Error('Invalid JSON from Claude: ' + responseContent.substring(0, 200));\n  }\n}\n\n// Validate required top-level fields\nconst requiredFields = [\n  'dream_outcome',\n  'value_equation',\n  'bonuses',\n  'guarantee',\n  'scarcity',\n  'urgency',\n  'offer_copy',\n  'total_value',\n  'anchor_price'\n];\n\nfor (const field of requiredFields) {\n  if (offer[field] === undefined || offer[field] === null) {\n    throw new Error(`Missing required field: ${field}`);\n  }\n}\n\n// Validate value_equation object\nconst veFields = ['likelihood', 'time_delay', 'effort_sacrifice'];\nif (!offer.value_equation || typeof offer.value_equation !== 'object') {\n  throw new Error('value_equation must be an object');\n}\nfor (const field of veFields) {\n  if (!offer.value_equation[field]) {\n    throw new Error(`value_equation missing field: ${field}`);\n  }\n}\n\n// Validate bonuses array\nif (!Array.isArray(offer.bonuses) || offer.bonuses.length !== 5) {\n  throw new Error(`Expected exactly 5 bonuses, got ${offer.bonuses.length}`);\n}\n\nfor (let i = 0; i < offer.bonuses.length; i++) {\n  const bonus = offer.bonuses[i];\n  if (!bonus.name || !bonus.value) {\n    throw new Error(`Bonus ${i + 1} missing name or value`);\n  }\n  if (typeof bonus.value !== 'number' || bonus.value <= 0) {\n    throw new Error(`Bonus ${i + 1} value must be positive number, got: ${bonus.value}`);\n  }\n}\n\n// Validate numeric fields\nif (typeof offer.total_value !== 'number' || offer.total_value <= 0) {\n  throw new Error(`total_value must be positive number, got: ${offer.total_value}`);\n}\nif (typeof offer.anchor_price !== 'number' || offer.anchor_price <= 0) {\n  throw new Error(`anchor_price must be positive number, got: ${offer.anchor_price}`);\n}\n\n// Validate text fields are not empty\nif (!offer.guarantee || offer.guarantee.trim().length === 0) {\n  throw new Error('guarantee cannot be empty');\n}\nif (!offer.scarcity || offer.scarcity.trim().length === 0) {\n  throw new Error('scarcity cannot be empty');\n}\nif (!offer.urgency || offer.urgency.trim().length === 0) {\n  throw new Error('urgency cannot be empty');\n}\nif (!offer.offer_copy || offer.offer_copy.trim().length === 0) {\n  throw new Error('offer_copy cannot be empty');\n}\n\nreturn offer;"
      },
      "id": "parse_claude_response",
      "name": "Parse & Validate Offer",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2.0,
      "position": [1650, 300]
