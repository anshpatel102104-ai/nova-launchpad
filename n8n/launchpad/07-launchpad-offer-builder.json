            }
          ]
        },
        "body": "{\n  \"user_id\": \"{{ $json.body.user_id }}\",\n  \"tool\": \"offer_builder\",\n  \"type\": \"offer\",\n  \"metadata\": {\n    \"core_product\": \"{{ $json.body.core_product }}\",\n    \"target_market\": \"{{ $json.body.target_market }}\",\n    \"price_target\": \"{{ $json.body.price_target }}\"\n  },\n  \"payload\": {\n    \"dream_outcome\": \"{{ $json.dream_outcome }}\",\n    \"value_equation\": {{ JSON.stringify($json.value_equation) }},\n    \"bonuses\": {{ JSON.stringify($json.bonuses) }},\n    \"guarantee\": \"{{ $json.guarantee }}\",\n    \"scarcity\": \"{{ $json.scarcity }}\",\n    \"urgency\": \"{{ $json.urgency }}\",\n    \"offer_copy\": \"{{ $json.offer_copy }}\",\n    \"total_value\": {{ $json.total_value }},\n    \"anchor_price\": {{ $json.anchor_price }},\n    \"offer_price\": {{ $json.body.price_target }}\n  },\n  \"created_at\": \"now()\"\n}",
        "options": {
          "headers": {
            "headers": [
              {
                "name": "apikey",
                "value": "={{ $env.SUPABASE_KEY }}"
              },
              {
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        }
      },
