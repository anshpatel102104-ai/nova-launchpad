    {
      "parameters": {
        "url": "={{ $env.ANTHROPIC_API_URL }}/v1/messages",
        "method": "POST",
        "authentication": "none",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "claude-opus-4-20250805"
            },
            {
              "name": "max_tokens",
              "value": "3000"
            }
          ]
        },
        "body": "{\n  \"model\": \"claude-opus-4-20250805\",\n  \"max_tokens\": 3000,\n  \"system\": \"You are an expert cold email copywriter specializing in high-converting B2B sales sequences. You understand ICP psychology, objection handling, and email sequencing best practices. Generate exactly 5 emails in the specified sequence: (1) Cold Opener - curiosity-driven hook, (2) Value-Add 1 - genuine insight/resource, (3) Social Proof - credibility/authority, (4) Soft CTA - low-friction ask, (5) Breakup - relationship closure. Each email must have: subject (max 50 characters), body (max 120 words), send_delay_days (1-7). OUTPUT ONLY VALID JSON with no markdown formatting or extra text. Format: [{ \\\"sequence_num\\\": 1, \\\"type\\\": \\\"cold_opener\\\", \\\"subject\\\": \\\"\\\", \\\"body\\\": \\\"\\\", \\\"send_delay_days\\\": 0 }, ...]\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Generate a 5-email cold sequence for: ICP: {{ $json.body.icp }}, Offer: {{ $json.body.offer }}, Sender: {{ $json.body.sender_name }} from {{ $json.body.sender_company }}, Brand Voice: {{ $json[0].brand_voice || 'professional, direct, consultative' }}, Tone: {{ $json[0].tone || 'consultative' }}. Each email max 120 words. Subjects max 50 chars. Return ONLY JSON array.\"\n    }\n  ]\n}"
      },
      "id": "call_claude_api",
      "name": "Call Claude Cold Email Sequencer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1450, 300],
      "onError": "continueErrorOutput",
      "credentials": [
        {
          "name": "anthropicApi",
          "type": "anthropicApi"
        }
      ]
    },
    {
      "parameters": {
        "jsCode": "// Extract Claude response from nested structure\nconst responseContent = $json.content[0].text;\n\n// Parse JSON from Claude\nlet sequence;\ntry {\n  sequence = JSON.parse(responseContent);\n} catch(e) {\n  // If Claude wrapped in markdown backticks, extract it\n  const jsonMatch = responseContent.match(/```json\\n?(.*?)\\n?```/s);\n  if (jsonMatch) {\n    sequence = JSON.parse(jsonMatch[1]);\n  } else if (responseContent.match(/^\\[/)) {\n    // Try raw array\n    sequence = JSON.parse(responseContent);\n  } else {\n    throw new Error('Invalid JSON from Claude: ' + responseContent.substring(0, 200));\n  }\n}\n\n// Validate it's an array with exactly 5 emails\nif (!Array.isArray(sequence) || sequence.length !== 5) {\n  throw new Error(`Expected 5 emails, got ${sequence.length}`);\n}\n\n// Validate each email\nconst emailTypes = ['cold_opener', 'value_add_1', 'social_proof', 'soft_cta', 'breakup'];\nfor (let i = 0; i < sequence.length; i++) {\n  const email = sequence[i];\n  const requiredFields = ['subject', 'body', 'send_delay_days'];\n  for (const field of requiredFields) {\n    if (!email[field]) {\n      throw new Error(`Email ${i + 1} missing field: ${field}`);\n    }\n  }\n  \n  // Validate constraints\n  if (email.subject.length > 50) {\n    throw new Error(`Email ${i + 1} subject exceeds 50 chars: ${email.subject.length}`);\n  }\n  if (email.body.split(' ').length > 120) {\n    throw new Error(`Email ${i + 1} body exceeds 120 words`);\n  }\n  if (email.send_delay_days < 0 || email.send_delay_days > 7) {\n    throw new Error(`Email ${i + 1} send_delay_days out of range: ${email.send_delay_days}`);\n  }\n  \n  // Ensure sequence_num and type\n  sequence[i].sequence_num = i + 1;\n  sequence[i].type = sequence[i].type || emailTypes[i];\n}\n\nreturn sequence;"
      },
      "id": "parse_claude_response",
      "name": "Parse & Validate Claude Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2.0,
      "position": [1650, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/tool_outputs",
        "method": "POST",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "user_id",
              "value": "={{ $json.body.user_id }}"
            },
            {
              "name": "tool",
              "value": "cold_email_sequencer"
            },
            {
              "name": "type",
              "value": "cold_email_sequence"
            },
            {
              "name": "created_at",
              "value": "=now()"
            }
          ]
        },
        "body": "{\n  \"user_id\": \"{{ $json.body.user_id }}\",\n  \"tool\": \"cold_email_sequencer\",\n  \"type\": \"cold_email_sequence\",\n  \"metadata\": {\n    \"icp\": \"{{ $json.body.icp }}\",\n    \"offer\": \"{{ $json.body.offer }}\",\n    \"sender_name\": \"{{ $json.body.sender_name }}\",\n    \"sender_company\": \"{{ $json.body.sender_company }}\"\n  },\n  \"payload\": {{ JSON.stringify($json) }},\n  \"created_at\": \"now()\"\n}",
        "options": {
          "headers": {
            "headers": [
              {
                "name": "apikey",
                "value": "={{ $env.SUPABASE_KEY }}"
              },
              {
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        }
      },
      "id": "insert_to_supabase",
      "name": "Insert to tool_outputs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1850, 300],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "{\n  \"success\": true,\n  \"sequence\": {{ JSON.stringify($json) }}\n}"
      },
