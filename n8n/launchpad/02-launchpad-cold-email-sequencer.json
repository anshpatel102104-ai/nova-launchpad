    {
      "parameters": {
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/user_ai_config",
        "method": "GET",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "options": {
          "headers": {
            "headers": [
              {
                "name": "apikey",
                "value": "={{ $env.SUPABASE_KEY }}"
