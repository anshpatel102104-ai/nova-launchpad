        "responseBody": "{\n  \"success\": true,\n  \"script\": {\n    \"sections\": {{ JSON.stringify($json.sections) }},\n    \"total_word_count\": {{ $json.total_word_count }},\n    \"est_runtime_seconds\": {{ $json.est_runtime_seconds }},\n    \"est_runtime_minutes\": {{ Math.round($json.est_runtime_seconds / 60 * 10) / 10 }}\n  }\n}"
      },
