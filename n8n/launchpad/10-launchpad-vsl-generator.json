    {
      "parameters": {
        "jsCode": "// Merge offer payload if provided\nlet offerContext = '';\nif ($items(1)?.[0]?.json?.body?.offer_id) {\n  const offerData = $json[0]?.payload;\n  if (offerData) {\n    offerContext = `\nOffer Context:\n- Dream Outcome: ${offerData.dream_outcome}\n- Total Value: $${offerData.total_value}\n- Bonuses: ${offerData.bonuses?.map(b => `${b.name} ($${b.value})`).join(', ')}\n- Guarantee: ${offerData.guarantee}\n- Scarcity: ${offerData.scarcity}\n- Urgency: ${offerData.urgency}`;\n  }\n}\n\nreturn {\n  offer_context: offerContext,\n  has_offer: !!offerContext\n};"
      },
      "id": "prepare_offer_context",
      "name": "Prepare Offer Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2.0,
      "position": [1650, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.ANTHROPIC_API_URL }}/v1/messages",
        "method": "POST",
        "authentication": "none",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "claude-opus-4-20250805"
            },
            {
              "name": "max_tokens",
              "value": "5000"
            }
          ]
        },
        "body": "{\n  \"model\": \"claude-opus-4-20250805\",\n  \"max_tokens\": 5000,\n  \"system\": \"You are an expert VSL (Video Sales Letter) copywriter specializing in high-converting direct response video scripts. You understand VSL psychology, pacing, objection handling, and video production requirements. Generate a complete VSL script for {{ $json.body.length_minutes }}-minute video. Include: hook (0-10s), problem agitation (problem identification), solution introduction, proof/social proof, offer presentation, objection handling, CTA, close. Each section has: timestamp (MM:SS), speaker_text, on_screen_text (visual cues for editor), b_roll_suggestion. Total word count ~{{ $json.body.length_minutes * 130 }} words (130 wpm = natural speaking pace). OUTPUT ONLY VALID JSON with no markdown formatting. Format: { \\\"sections\\\": [{ \\\"timestamp\\\": \\\"MM:SS\\\", \\\"section_name\\\": \\\"\\\", \\\"speaker_text\\\": \\\"\\\", \\\"on_screen_text\\\": \\\"\\\", \\\"b_roll_suggestion\\\": \\\"\\\" }, ...], \\\"total_word_count\\\": number, \\\"est_runtime_seconds\\\": number }\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Generate a {{ $json.body.length_minutes }}-minute VSL script for: Product: {{ $json.body.product_summary }}, Target Audience: {{ $json.body.target_audience }}, Brand Voice: {{ $json[1][0].brand_voice || 'professional and persuasive' }}, Tone: {{ $json[1][0].tone || 'direct response' }}. {{ $json.offer_context }}. Script should: hook in first 10 seconds, agitate pain for 30s, present solution for 45s, show proof/testimonials for 1m, present offer with guarantee for 1-2m, handle top 3 objections for 1m, close with CTA for 30s. Calculate word count (130 wpm = natural pace). Return ONLY JSON with sections array.\"\n    }\n  ]\n}"
      },
      "id": "call_claude_api",
      "name": "Call Claude VSL Generator",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1850, 300],
      "onError": "continueErrorOutput",
      "credentials": [
        {
          "name": "anthropicApi",
          "type": "anthropicApi"
        }
      ]
    },
    {
      "parameters": {
        "jsCode": "// Extract Claude response from nested structure\nconst responseContent = $json.content[0].text;\n\n// Parse JSON from Claude\nlet vsl;\ntry {\n  vsl = JSON.parse(responseContent);\n} catch(e) {\n  // If Claude wrapped in markdown backticks, extract it\n  const jsonMatch = responseContent.match(/```json\\n?(.*?)\\n?```/s);\n  if (jsonMatch) {\n    vsl = JSON.parse(jsonMatch[1]);\n  } else if (responseContent.match(/^\\{/)) {\n    // Try raw object\n    vsl = JSON.parse(responseContent);\n  } else {\n    throw new Error('Invalid JSON from Claude: ' + responseContent.substring(0, 200));\n  }\n}\n\n// Validate required fields\nif (!vsl.sections || !Array.isArray(vsl.sections)) {\n  throw new Error('sections must be an array');\n}\n\nif (vsl.sections.length < 5) {\n  throw new Error(`Expected minimum 5 sections, got ${vsl.sections.length}`);\n}\n\n// Validate each section\nfor (let i = 0; i < vsl.sections.length; i++) {\n  const section = vsl.sections[i];\n  const requiredFields = ['timestamp', 'section_name', 'speaker_text', 'on_screen_text', 'b_roll_suggestion'];\n  \n  for (const field of requiredFields) {\n    if (!section[field]) {\n      throw new Error(`Section ${i + 1} missing field: ${field}`);\n    }\n  }\n  \n  // Validate timestamp format MM:SS or M:SS\n  const timeMatch = section.timestamp.match(/^\\d{1,2}:\\d{2}$/);\n  if (!timeMatch) {\n    throw new Error(`Section ${i + 1} invalid timestamp format: ${section.timestamp}`);\n  }\n  \n  // Convert timestamp to seconds for validation\n  const [mins, secs] = section.timestamp.split(':').map(Number);\n  const totalSecs = mins * 60 + secs;\n  if (totalSecs > 900) { // More than 15 minutes\n    throw new Error(`Section ${i + 1} timestamp exceeds 15 minutes: ${section.timestamp}`);\n  }\n}\n\n// Validate numeric fields\nif (typeof vsl.total_word_count !== 'number' || vsl.total_word_count <= 0) {\n  throw new Error(`total_word_count must be positive number, got: ${vsl.total_word_count}`);\n}\n\nif (typeof vsl.est_runtime_seconds !== 'number' || vsl.est_runtime_seconds <= 0) {\n  throw new Error(`est_runtime_seconds must be positive number, got: ${vsl.est_runtime_seconds}`);\n}\n\n// Warn if runtime doesn't match target\nconst targetSeconds = $items(1)[0].json.body.length_minutes * 60;\nconst runtimeDiff = Math.abs(vsl.est_runtime_seconds - targetSeconds);\nif (runtimeDiff > 120) { // More than 2 minutes off\n  console.warn(`Runtime mismatch: target ${targetSeconds}s, got ${vsl.est_runtime_seconds}s`);\n}\n\nreturn vsl;"
      },
      "id": "parse_claude_response",
      "name": "Parse & Validate VSL Script",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2.0,
      "position": [2050, 300]
