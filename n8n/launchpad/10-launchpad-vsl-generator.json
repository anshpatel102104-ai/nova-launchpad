              "name": "type",
              "value": "vsl_script"
            },
            {
              "name": "created_at",
              "value": "=now()"
            }
          ]
        },
        "body": "{\n  \"user_id\": \"{{ $json.body.user_id }}\",\n  \"tool\": \"vsl_generator\",\n  \"type\": \"vsl_script\",\n  \"metadata\": {\n    \"product_summary\": \"{{ $json.body.product_summary }}\",\n    \"target_audience\": \"{{ $json.body.target_audience }}\",\n    \"length_minutes\": {{ $json.body.length_minutes }},\n    \"offer_id\": \"{{ $json.body.offer_id || null }}\"\n  },\n  \"payload\": {\n    \"sections\": {{ JSON.stringify($json.sections) }},\n    \"total_word_count\": {{ $json.total_word_count }},\n    \"est_runtime_seconds\": {{ $json.est_runtime_seconds }},\n    \"product_summary\": \"{{ $json.body.product_summary }}\",\n    \"target_audience\": \"{{ $json.body.target_audience }}\"\n  },\n  \"created_at\": \"now()\"\n}",
        "options": {
          "headers": {
            "headers": [
              {
                "name": "apikey",
                "value": "={{ $env.SUPABASE_KEY }}"
              },
              {
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        }
      },
      "id": "insert_to_supabase",
