        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"onboarding_status\": \"complete\",\n  \"operator_active\": true,\n  \"activated_at\": \"{{ $json.now }}\",\n  \"activation_count\": 1,\n  \"updated_at\": \"{{ $json.now }}\"\n}",
        "options": {},
        "nodeCredentialType": "supabaseApi"
      },
