      },
      "id": "r1000001-0001-0001-0001-000000000001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        400
      ],
      "webhookId": "nova-ops-operator-handoff"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst user_id       = body.user_id       || null;\nconst triggered_by  = body.triggered_by  || 'system';   // 'system' | 'admin' | 'user'\nconst force_reactivate = body.force_reactivate === true; // allow re-activation from admin\n\nif (!user_id) throw new Error('Missing required field: user_id');\n\nreturn [{\n  json: {\n    user_id,\n    triggered_by,\n    force_reactivate,\n    now: new Date().toISOString()\n  }\n}];"
      },
      "id": "r1000001-0002-0002-0002-000000000002",
      "name": "Parse & Validate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        400
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/users?user_id=eq.{{ $json.user_id }}&select=user_id,email,onboarding_status,operator_active,plan_tier,plan_status",
        "authentication": "predefinedCredentialType",
        "sendHeaders": false,
        "options": {},
        "nodeCredentialType": "supabaseApi"
      },
      "id": "r1000001-0003-0003-0003-000000000003",
      "name": "GET users: pre-flight check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        720,
        400
      ],
      "credentials": {
        "supabaseApi": {
          "id": "xbPYfxBm7UismiBl",
          "name": "SUPABASE_PROD_SERVICE_ROLE"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const fetchResult = $input.first().json;\nconst origin = $('Parse & Validate').first().json;\n\nconst record = Array.isArray(fetchResult) ? fetchResult[0] : fetchResult;\n\nif (!record?.user_id) {\n  throw new Error(`No users record found for user_id: ${origin.user_id}. Cannot activate operator.`);\n}\n\nconst plan_status    = (record.plan_status || 'active').toLowerCase();\nconst onboarding_status = record.onboarding_status || 'pending';\nconst operator_active   = record.operator_active === true;\nconst plan_tier         = (record.plan_tier || 'free').toLowerCase();\n\n// Block activation if account is suspended\nconst is_suspended = plan_status === 'suspended' || plan_status === 'deleted';\n\n// Already active \u2014 skip unless force_reactivate\nconst already_active = operator_active && !origin.force_reactivate;\n\nreturn [{\n  json: {\n    ...origin,\n    email:            record.email || '',\n    plan_tier,\n    plan_status,\n    onboarding_status,\n    operator_active,\n    is_suspended,\n    already_active,\n    can_activate:     !is_suspended && !already_active\n  }\n}];"
      },
      "id": "r1000001-0004-0004-0004-000000000004",
      "name": "Pre-Flight Validation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "suspended-check",
              "leftValue": "={{ $json.is_suspended }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "r1000001-0005-0005-0005-000000000005",
      "name": "Account Suspended?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1200,
        260
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"success\": false,\n  \"operator_active\": false,\n  \"reason\": \"account_suspended\",\n  \"message\": \"Cannot activate operator \u2014 account is {{ $json.plan_status }}. Restore billing to reactivate.\",\n  \"user_id\": \"{{ $json.user_id }}\",\n  \"plan_status\": \"{{ $json.plan_status }}\"\n}",
        "options": {
          "responseCode": 403
        }
      },
      "id": "r1000001-0006-0006-0006-000000000006",
      "name": "Return: 403 Suspended",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        1440,
        160
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "already-active-check",
              "leftValue": "={{ $json.already_active }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "r1000001-0007-0007-0007-000000000007",
      "name": "Already Active?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1200,
        540
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"success\": true,\n  \"operator_active\": true,\n  \"action\": \"already_active\",\n  \"message\": \"Operator is already active for this user. Pass force_reactivate=true to reset.\",\n  \"user_id\": \"{{ $json.user_id }}\",\n  \"plan_tier\": \"{{ $json.plan_tier }}\"\n}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "r1000001-0008-0008-0008-000000000008",
