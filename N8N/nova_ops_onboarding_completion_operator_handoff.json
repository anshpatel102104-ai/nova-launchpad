        "jsonBody": "={\n  \"user_id\": \"{{ $json.user_id }}\",\n  \"type\": \"operator_active\",\n  \"title\": \"\u26a1 Your AI operator is live\",\n  \"message\": \"Your Nova OPS AI operator is now active and ready to work. Head to your Launchpad to run your first tool.\",\n  \"action_label\": \"Open Launchpad\",\n  \"action_url\": \"/dashboard/{{ $json.user_id }}/launchpad\",\n  \"metadata\": {{ JSON.stringify({ session_id: $json.session_id, plan_tier: $json.plan_tier, activated_at: $json.now, triggered_by: $json.triggered_by }) }},\n  \"read\": false,\n  \"created_at\": \"{{ $json.now }}\"\n}",
