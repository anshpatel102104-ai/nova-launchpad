        "jsonBody": "={\n  \"user_id\": \"{{ $('Pre-Flight Validation').first().json.user_id }}\",\n  \"session_type\": \"initial_activation\",\n  \"context\": \"onboarding_complete\",\n  \"triggered_by\": \"{{ $('Pre-Flight Validation').first().json.triggered_by }}\",\n  \"plan_tier\": \"{{ $('Pre-Flight Validation').first().json.plan_tier }}\",\n  \"started_at\": \"{{ $('Pre-Flight Validation').first().json.now }}\",\n  \"ended_at\": null,\n  \"status\": \"active\"\n}",
        "options": {},
        "nodeCredentialType": "supabaseApi"
      },
      "id": "r1000001-0010-0010-0010-000000000010",
      "name": "INSERT operator_sessions",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1440,
        880
      ],
      "credentials": {
        "supabaseApi": {
          "id": "xbPYfxBm7UismiBl",
          "name": "SUPABASE_PROD_SERVICE_ROLE"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst origin = $('Pre-Flight Validation').first().json;\n\nif (!items || items.length < 2) {\n  throw new Error(`Expected 2 write results (users PATCH + operator_sessions INSERT), got ${items?.length || 0}`);\n}\n\nconst patchRaw  = items[0].json;\nconst sessionRaw = items[1].json;\n\nconst patchRecord   = Array.isArray(patchRaw)   ? patchRaw[0]   : patchRaw;\nconst sessionRecord = Array.isArray(sessionRaw) ? sessionRaw[0] : sessionRaw;\n\nconst users_patched    = patchRecord?.user_id   !== undefined;\nconst session_created  = sessionRecord?.id      !== undefined;\nconst session_id       = sessionRecord?.id      || null;\n\nif (!users_patched) {\n  throw new Error(`PATCH to users returned no record for user_id: ${origin.user_id}. Check Supabase RLS.`);\n}\nif (!session_created) {\n  console.warn(`operator_sessions INSERT may have failed for user ${origin.user_id}. Response: ${JSON.stringify(sessionRaw)}`);\n}\n\nreturn [{\n  json: {\n    ...origin,\n    users_patched,\n    session_created,\n    session_id\n  }\n}];"
      },
