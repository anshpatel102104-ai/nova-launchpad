      "parameters": {
        "jsCode": "const items = $input.all();\nconst origin = $('Parse & Validate').first().json;\n\nif (!items || items.length === 0) {\n  throw new Error('No results received from parallel reactivation patches');\n}\n\nreturn [{\n  json: {\n    user_id: origin.user_id,\n    plan_tier: origin.plan_tier,\n    now: origin.now,\n    branches_completed: items.length\n  }\n}];"
      },
