    {
      "parameters": {
        "jsCode": "const stripeResult = $input.first().json;\nconst origin = $('Parse & Validate').first().json;\n\nconst subscription_id = stripeResult?.data?.[0]?.id || null;\nconst has_subscription = !!subscription_id;\n\nreturn [{\n  json: {\n    ...origin,\n    subscription_id,\n    has_subscription\n  }\n}];"
      },
