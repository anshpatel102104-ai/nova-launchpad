      "parameters": {
        "jsCode": "const items = $input.all();\nconst origin = $('Build Archive Payload').first().json;\n\nif (!items || items.length === 0) throw new Error('No results from deletion steps');\n\nreturn [{\n  json: {\n    user_id: origin.user_id,\n    email: origin.email,\n    stripe_customer_id: origin.stripe_customer_id,\n    deleted_by: origin.deleted_by,\n    stripe_cancelled: origin.stripe_cancelled,\n    now: origin.now,\n    deletion_steps_completed: items.length\n  }\n}];"
