    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst user_id            = body.user_id || null;\nconst email              = body.email || null;\nconst stripe_customer_id = body.stripe_customer_id || null;\nconst deleted_by         = (body.deleted_by || 'user').toLowerCase();\n\nif (!user_id) throw new Error('Missing required field: user_id');\nif (!email)   throw new Error('Missing required field: email');\n\nreturn [{\n  json: {\n    user_id,\n    email,\n    stripe_customer_id,\n    deleted_by,  // 'user' | 'admin'\n    now: new Date().toISOString()\n  }\n}];"
      },
      "id": "h1000001-0002-0002-0002-000000000002",
