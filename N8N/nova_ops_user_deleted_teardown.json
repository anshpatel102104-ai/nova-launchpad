    {
      "parameters": {
        "jsCode": "const profileResult = $input.first().json;\nconst origin = $('Merge Stripe Paths').first().json;\n\nconst profile = Array.isArray(profileResult) ? profileResult[0] : profileResult;\n\nreturn [{\n  json: {\n    ...origin,\n    profile_snapshot: profile || {}\n  }\n}];"
      },
