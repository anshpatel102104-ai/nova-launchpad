        "jsCode": "// No active sub or no Stripe customer — pass through cleanly\nconst origin = $('Parse & Validate').first().json;\nreturn [{\n  json: {\n    ...origin,\n    subscription_id: null,\n    has_subscription: false,\n    stripe_cancelled: false,\n    stripe_skip_reason: 'no_active_subscription'\n  }\n}];"
