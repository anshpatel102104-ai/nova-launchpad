        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"from\": \"Nova OPS <noreply@nova-ops.space>\",\n  \"to\": [\"{{ $json.email }}\"],\n  \"subject\": \"Your Nova OPS account has been deleted\",\n  \"html\": \"<div style='font-family:sans-serif;max-width:560px;margin:0 auto;color:#1a1a1a'><h2 style='color:#0f172a'>Your account has been deleted</h2><p>Hi there,</p><p>Your Nova OPS account associated with <strong>{{ $json.email }}</strong> has been permanently deleted as requested.</p><ul><li>Your subscription has been cancelled — no further charges will occur</li><li>All your data has been removed from our systems</li><li>Any remaining credits have been cleared</li></ul><p>If you didn't request this deletion or believe this was a mistake, please contact us immediately at <a href='mailto:support@nova-ops.space'>support@nova-ops.space</a>.</p><hr style='border:none;border-top:1px solid #e2e8f0;margin:24px 0'/><p style='font-size:13px;color:#64748b'>We're sorry to see you go. If you ever want to come back, you can create a new account at <a href='https://nova-ops.space'>nova-ops.space</a>.</p><p style='font-size:12px;color:#94a3b8'>Nova OPS · Tampa, FL</p></div>\",\n  \"text\": \"Your Nova OPS account ({{ $json.email }}) has been permanently deleted. Your subscription has been cancelled and all data removed. Questions? support@nova-ops.space\"\n}",
        "options": {}
