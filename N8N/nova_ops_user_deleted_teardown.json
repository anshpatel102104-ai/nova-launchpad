        "jsCode": "// No Stripe customer at all — pass through cleanly\nconst origin = $('Parse & Validate').first().json;\nreturn [{\n  json: {\n    ...origin,\n    subscription_id: null,\n    has_subscription: false,\n    stripe_cancelled: false,\n    stripe_skip_reason: 'no_stripe_customer'\n  }\n}];"
      },
