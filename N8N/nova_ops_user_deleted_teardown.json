    {
      "parameters": {
        "jsCode": "// Normalise all three Stripe paths into one shape\nconst items = $input.all();\nif (!items || items.length === 0) throw new Error('No data from Stripe path');\n\nconst d = items[0].json;\nconst origin = $('Parse & Validate').first().json;\n\n// If from DELETE node, shape is Stripe sub object — extract id\nconst cancelled_id = d?.id || d?.subscription_id || null;\nconst stripe_cancelled = d?.status === 'canceled' || false;\n\nreturn [{\n  json: {\n    user_id: origin.user_id,\n    email: origin.email,\n    stripe_customer_id: origin.stripe_customer_id,\n    deleted_by: origin.deleted_by,\n    now: origin.now,\n    subscription_id: cancelled_id || d?.subscription_id || null,\n    stripe_cancelled,\n    stripe_skip_reason: d?.stripe_skip_reason || null\n  }\n}];"
      },
