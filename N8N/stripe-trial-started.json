{
  "name": "Stripe Trial Started",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "stripe-trial-started",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "d4e5f6a7-0001-0001-0001-000000000001",
      "name": "Stripe Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "webhookId": "stripe-trial-started"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst event = body;\nconst eventType = event?.type || '';\nconst subscription = event?.data?.object || {};\n\nconst customerId = subscription.customer || '';\nconst subscriptionId = subscription.id || '';\nconst status = subscription.status || '';\nconst trialEnd = subscription.trial_end || null;\n\n// Accept both event types\nconst isTrialEvent =\n  eventType === 'customer.subscription.trial_will_end' ||\n  (eventType === 'customer.subscription.created' && status === 'trialing');\n\nif (!isTrialEvent || !trialEnd) {\n  return [{ json: { skip: true, reason: 'Not a trial event or no trial_end', eventType, status } }];\n}\n\nconst trialEndDate = new Date(trialEnd * 1000);\nconst now = new Date();\n\n// Calculate wait times in milliseconds\nconst msUntilTrialEnd = trialEndDate.getTime() - now.getTime();\nconst msUntil72hr = msUntilTrialEnd - (72 * 60 * 60 * 1000);\nconst msUntil24hr = msUntilTrialEnd - (24 * 60 * 60 * 1000);\n\n// Convert to seconds for n8n Wait node\nconst waitSeconds72hr = Math.max(Math.floor(msUntil72hr / 1000), 0);\nconst waitSeconds24hr = Math.max(Math.floor(msUntil24hr / 1000), 0);\n\nreturn [{ json: {\n  customerId,\n  subscriptionId,\n  status,\n  eventType,\n  isTrialEvent,\n  skip: false,\n  trialEnd,\n  trialEndIso: trialEndDate.toISOString(),\n  trialEndDisplay: trialEndDate.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }),\n  waitSeconds72hr,\n  waitSeconds24hr,\n  msUntil72hr,\n  msUntil24hr,\n  rawPayload: JSON.stringify(body)\n} }];"
      },
      "id": "d4e5f6a7-0002-0002-0002-000000000002",
      "name": "Parse Trial Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "check-skip",
              "leftValue": "={{ $json.skip }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equal" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "d4e5f6a7-0003-0003-0003-000000000003",
      "name": "Should Skip?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "OK - Skipped",
        "options": { "responseCode": 200 }
      },
      "id": "d4e5f6a7-0004-0004-0004-000000000004",
      "name": "Return 200 Skipped",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [900, 480]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/users",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "stripe_customer_id", "value": "=eq.{{ $('Parse Trial Payload').first().json.customerId }}" },
            { "name": "select", "value": "email,first_name,stripe_customer_id" }
          ]
        },
        "options": {}
      },
      "id": "d4e5f6a7-0005-0005-0005-000000000005",
      "name": "Get User from Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [900, 300]
    },
    {
      "parameters": {
        "jsCode": "const users = $input.first().json;\nconst user = Array.isArray(users) ? users[0] : users;\nconst parsed = $('Parse Trial Payload').first().json;\nreturn [{ json: {\n  ...parsed,\n  email: user?.email || '',\n  firstName: user?.first_name || 'there'\n} }];"
      },
      "id": "d4e5f6a7-0006-0006-0006-000000000006",
      "name": "Merge User Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/users",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=representation" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "stripe_customer_id", "value": "=eq.{{ $json.customerId }}" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"plan_status\": \"trialing\",\n  \"trial_ends_at\": \"{{ $json.trialEndIso }}\",\n  \"updated_at\": \"{{ $now.toISO() }}\"\n}",
        "options": { "response": { "response": { "neverError": true, "responseFormat": "json" } } }
      },
      "id": "d4e5f6a7-0007-0007-0007-000000000007",
      "name": "Update User Trial Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.RESEND_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"from\": \"Nova OPS <hello@nova-ops.space>\",\n  \"to\": [\"{{ $('Merge User Data').first().json.email }}\"],\n  \"subject\": \"Your Nova OPS trial has started 🚀\",\n  \"html\": \"<h1>Welcome to Nova OPS, {{ $('Merge User Data').first().json.firstName }}!</h1><p>Your free trial is now active and runs until <strong>{{ $('Merge User Data').first().json.trialEndDisplay }}</strong>.</p><h2>Here's what to explore during your trial:</h2><ul><li><strong>Launchpad</strong> — 10 AI founder tools to build, validate and launch faster</li><li><strong>Nova OS</strong> — 6 business automation systems that run your ops on autopilot</li><li><strong>Lead Gen Automation</strong> — Set up your first automated pipeline</li><li><strong>Client Onboarding System</strong> — Deliver a world-class client experience from day one</li></ul><p><a href='https://nova-ops.space/dashboard'>👉 Log in and start exploring</a></p><p>Reply to this email anytime if you have questions — we respond fast.</p><p>— The Nova OPS Team</p>\"\n}",
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "d4e5f6a7-0008-0008-0008-000000000008",
      "name": "Send Trial Welcome Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1560, 300]
    },
    {
