        "amount": "={{ $('Merge User Data').first().json.waitSeconds72hr }}",
        "unit": "seconds"
      },
      "id": "d4e5f6a7-0010-0010-0010-000000000010",
      "name": "Wait Until 72hr Before End",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [1560, 520],
      "webhookId": "wait-72hr"
    },
    {
      "parameters": {
