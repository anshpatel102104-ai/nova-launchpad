        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"email\": \"{{ $('Merge User Data').first().json.email }}\",\n  \"firstName\": \"{{ $('Merge User Data').first().json.firstName }}\",\n  \"customerId\": \"{{ $('Merge User Data').first().json.customerId }}\",\n  \"trialEndIso\": \"{{ $('Merge User Data').first().json.trialEndIso }}\",\n  \"trialEndDisplay\": \"{{ $('Merge User Data').first().json.trialEndDisplay }}\",\n  \"warningType\": \"72hr\"\n}",
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "d4e5f6a7-0011-0011-0011-000000000011",
      "name": "Trigger 72hr Warning Webhook",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
