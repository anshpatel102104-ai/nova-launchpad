      "parameters": {
        "jsCode": "// Merge renewal context with fetched lifetime_granted\nconst mergeNode = $('Merge Credit Branches').first().json;\nconst fetchResult = $input.first().json;\n\nconst currentLifetime = fetchResult[0]?.lifetime_granted || 0;\nconst newLifetime = currentLifetime + mergeNode.credit_amount;\n\nreturn [{\n  json: {\n    user_id: mergeNode.user_id,\n    plan_tier: mergeNode.plan_tier,\n    trigger_type: mergeNode.trigger_type,\n    now: mergeNode.now,\n    credit_amount: mergeNode.credit_amount,\n    new_lifetime_granted: newLifetime\n  }\n}];"
      },
