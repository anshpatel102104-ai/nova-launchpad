      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst user_id = body.user_id || null;\nconst plan_tier = (body.plan_tier || 'free').toLowerCase().trim();\nconst trigger_type = (body.trigger_type || 'init').toLowerCase().trim();\n\nif (!user_id) throw new Error('Missing required field: user_id');\n\nconst validTiers = ['free', 'starter', 'pro', 'scale'];\nconst validTriggers = ['init', 'renewal'];\n\nconst resolvedTier = validTiers.includes(plan_tier) ? plan_tier : 'free';\nconst resolvedTrigger = validTriggers.includes(trigger_type) ? trigger_type : 'init';\n\nreturn [{\n  json: {\n    user_id,\n    plan_tier: resolvedTier,\n    trigger_type: resolvedTrigger,\n    now: new Date().toISOString()\n  }\n}];"
      },
