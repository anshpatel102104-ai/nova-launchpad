      "parameters": {
        "jsCode": "// Normalise both init and renewal outputs into a single shape for the event log\nconst items = $input.all();\nif (!items || items.length === 0) throw new Error('No data flowing into event log merge');\nconst d = items[0].json;\n\n// init branch returns array from Supabase; renewal branch returns array from PATCH\nconst record = Array.isArray(d) ? d[0] : d;\n\n// Pull originals from Merge Credit Branches node (always in context)\nconst origin = $('Merge Credit Branches').first().json;\n\nreturn [{\n  json: {\n    user_id: record.user_id || origin.user_id,\n    plan_tier: record.plan_tier || origin.plan_tier,\n    trigger_type: origin.trigger_type,\n    credit_amount: origin.credit_amount,\n    now: origin.now\n  }\n}];"
      },
