    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst user_id = body.user_id || body.record?.id || null;\nconst email = body.email || body.record?.email || null;\nconst plan_tier = (body.plan_tier || 'free').toLowerCase().trim();\n\nif (!user_id || !email) {\n  throw new Error('Missing required fields: user_id or email');\n}\n\nconst creditMap = {\n  free: { credits: 10, unlimited: false },\n  starter: { credits: 100, unlimited: false },\n  pro: { credits: 500, unlimited: false },\n  scale: { credits: 0, unlimited: true }\n};\n\nconst creditConfig = creditMap[plan_tier] || creditMap['free'];\n\nreturn [{\n  json: {\n    user_id,\n    email,\n    plan_tier,\n    role: 'member',\n    credits: creditConfig.credits,\n    unlimited: creditConfig.unlimited,\n    created_at: new Date().toISOString()\n  }\n}];"
      },
      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "name": "Parse & Map Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 300]
    },
    {
      "parameters": {
