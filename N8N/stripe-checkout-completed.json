        "jsonBody": "={\n  \"email\": \"{{ $json.customerEmail }}\",\n  \"stripe_customer_id\": \"{{ $json.customerId }}\",\n  \"stripe_subscription_id\": \"{{ $json.subscriptionId }}\",\n  \"plan_tier\": \"{{ $json.planTier }}\",\n  \"status\": \"active\",\n  \"business_name\": \"{{ $json.businessName }}\",\n  \"niche\": \"{{ $json.niche }}\",\n  \"created_at\": \"{{ $json.createdAt }}\"\n}",
        "options": {
