                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "scale"
            }
          ]
        },
        "options": { "fallbackOutput": "extra" }
      },
      "id": "b1000001-0003-0003-0003-000000000003",
      "name": "Switch: Plan Tier",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.1,
      "position": [720, 400]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nreturn [{\n  json: {\n    user_id: input.user_id,\n    plan_tier: 'free',\n    updated_at: input.updated_at,\n    launchpad_tool_1: true,\n    launchpad_tool_2: true,\n    launchpad_tool_3: false,\n    launchpad_tool_4: false,\n    launchpad_tool_5: false,\n    launchpad_tool_6: false,\n    launchpad_tool_7: false,\n    launchpad_tool_8: false,\n    launchpad_tool_9: false,\n    launchpad_tool_10: false,\n    nova_os_lead_capture: false,\n    nova_os_followup: false,\n    nova_os_booking: false,\n    nova_os_nurture: false,\n    nova_os_reporting: false,\n    nova_os_sales: false,\n    ai_operator_access: false,\n    subagent_access: false,\n    credits_monthly_allotment: 10\n  }\n}];"
      },
