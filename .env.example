# ─── Supabase (public) ──────────────────────────────────────────────
# REQUIRES: Supabase Dashboard → Project Settings → API → anon public key
VITE_SUPABASE_URL="https://snnnbzhopsajrhimhgje.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_PROJECT_ID="snnnbzhopsajrhimhgje"

# ─── Stripe ─────────────────────────────────────────────────────────
# REQUIRES: Stripe Dashboard → Developers → API keys → Publishable key
# Use pk_test_... for sandbox, pk_live_... for production
VITE_PAYMENTS_CLIENT_TOKEN=""

# ─── n8n subagents ──────────────────────────────────────────────────
# Direct mode: VITE_N8N_BASE_URL="https://n8n.nova-ops.space"
# Proxy mode (recommended): leave as /api/n8n (routes through Cloudflare worker)
VITE_N8N_BASE_URL="/api/n8n"

# ─── Supabase server-side (Edge Functions & Cloudflare worker) ───────
# REQUIRES: Supabase Dashboard → Project Settings → API → service_role secret key
SUPABASE_SERVICE_ROLE_KEY=""
# REQUIRES: Supabase Dashboard → Project Settings → API → anon public key
SUPABASE_ANON_KEY=""
SUPABASE_URL="https://snnnbzhopsajrhimhgje.supabase.co"

# ─── Lovable AI Gateway ─────────────────────────────────────────────
# REQUIRES: Auto-provisioned by Lovable Cloud; visible in Lovable project secrets
LOVABLE_API_KEY=""

# ─── Stripe server-side (Edge Functions) ────────────────────────────
# REQUIRES: Stripe Dashboard → Developers → API keys → Secret key (sk_test_ / sk_live_)
STRIPE_SANDBOX_API_KEY=""
STRIPE_LIVE_API_KEY=""
# REQUIRES: Stripe Dashboard → Developers → Webhooks → Signing secret (whsec_...)
PAYMENTS_SANDBOX_WEBHOOK_SECRET=""
PAYMENTS_LIVE_WEBHOOK_SECRET=""

# ─── Integrations encryption ─────────────────────────────────────────
# REQUIRES: Generate with: openssl rand -base64 32
# Used by save-integration edge function to AES-256 encrypt stored API keys
INTEGRATIONS_ENCRYPTION_KEY=""

# ─── Cloudflare Worker (n8n proxy) ───────────────────────────────────
# REQUIRES: Generate with: openssl rand -hex 32
# Set in Cloudflare: npx wrangler secret put N8N_PROXY_SECRET (in cloudflare/n8n-proxy/)
# Also set as N8N_PROXY_SECRET env var on the n8n host so it can verify the header
N8N_PROXY_SECRET=""
# REQUIRES: Supabase Dashboard → Project Settings → API → JWT Secret
# Set in Cloudflare: npx wrangler secret put SUPABASE_JWT_SECRET (in cloudflare/n8n-proxy/)
SUPABASE_JWT_SECRET=""

# ─── n8n host (server-only, set in n8n environment / .env on n8n server) ───
# REQUIRES: Your n8n instance URL
N8N_WEBHOOK_BASE_URL="https://n8n.nova-ops.space"
# REQUIRES: Anthropic Console → API Keys (console.anthropic.com)
ANTHROPIC_API_KEY=""
# Credit deduction webhook — matches the Credit Ledger · Deduct n8n workflow
CREDIT_DEDUCTION_WEBHOOK_URL="https://n8n.nova-ops.space/webhook/credit-ledger-deduct"

# ─── n8n global variables (set in n8n Settings → Variables UI) ──────
# REQUIRES: your production app domain
GLOBAL_APP_URL_PROD="https://nova-ops.space"
GLOBAL_APP_URL_STG="https://stg.nova-ops.space"
# REQUIRES: Slack incoming webhook URL, or an internal error-catching endpoint
GLOBAL_ERROR_WEBHOOK_URL=""
# Claude model used by default in all operator workflows
GLOBAL_AI_MODEL_DEFAULT="claude-sonnet-4-6"
# REQUIRES: Slack incoming webhook for ops alerts (optional — omit to skip Slack alerts)
GLOBAL_SLACK_ALERT_CHANNEL=""
# REQUIRES: Generate with: openssl rand -hex 16  — secures the prompt-swap webhook
NOVA_OPS_ADMIN_TOKEN=""
# Points to the in-app billing upgrade page
STRIPE_UPGRADE_URL="https://nova-ops.space/app/billing"
